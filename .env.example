# ==============================================================================
# TIPITAKA PALI READER - ENVIRONMENT & API KEY SETUP INSTRUCTIONS
# ==============================================================================
#
# WHY THIS FILE IS REQUIRED:
# This project uses `package:envied` with `obfuscate: true` to encrypt API keys.
# The keys are compiled into byte arrays in a generated file (`lib/env/env.g.dart`).
# Because `.env` and `env.g.dart` contain secret keys, they are `.gitignore`d.
#
# ------------------------------------------------------------------------------
# 1. REQUIRED DIRECTORY & FILE LOCATION:
# ------------------------------------------------------------------------------
# You MUST place your `.env` file inside the `lib/env/` directory:
#
#   Target File Path:  lib/env/.env
#
# (Do NOT place `.env` in the project root; `build_runner` requires it inside `lib/env/`).
#
# ------------------------------------------------------------------------------
# 2. REQUIRED FILES SUMMARY:
# ------------------------------------------------------------------------------
#   - `lib/env/env.dart`        : (Committed) Defines the Env class annotated with @Envied.
#   - `lib/env/.env`            : (Ignored) Contains your raw API key key=value pairs.
#   - `lib/env/env.g.dart`      : (Ignored) Auto-generated obfuscated Dart code.
#
# ------------------------------------------------------------------------------
# 3. SETUP COMMANDS (RUN IN TERMINAL FROM PROJECT ROOT):
# ------------------------------------------------------------------------------
# Step 1: Copy this example file to `lib/env/.env`
#   (Windows PowerShell):  Copy-Item .env.example lib/env/.env
#   (Mac/Linux Terminal):  cp .env.example lib/env/.env
#
# Step 2: Edit `lib/env/.env` and replace placeholder keys with your real API keys.
#
# Step 3: Fetch Flutter dependencies:
#   flutter pub get
#
# Step 4: Run build_runner to generate `lib/env/env.g.dart` (REQUIRED):
#   dart run build_runner build --delete-conflicting-outputs
#
# (Optional) Watch mode during development:
#   dart run build_runner watch --delete-conflicting-outputs
# ==============================================================================

FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY_HERE"
OPEN_ROUTER_API_KEY="YOUR_OPEN_ROUTER_API_KEY_HERE"
